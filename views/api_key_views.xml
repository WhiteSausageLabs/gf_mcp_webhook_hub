<odoo>
    <record id="view_gf_mcp_api_key_tree" model="ir.ui.view">
        <field name="name">gf.mcp.api.key.tree</field>
        <field name="model">gf.mcp.api.key</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
                <field name="key_preview"/>
                <field name="read_only"/>
                <field name="last_used_at"/>
            </list>
        </field>
    </record>
    <record id="view_gf_mcp_api_key_form" model="ir.ui.view">
        <field name="name">gf.mcp.api.key.form</field>
        <field name="model">gf.mcp.api.key</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="key_preview" readonly="True"/>
                        <field name="read_only"/>
                        <field name="last_used_at" readonly="True"/>
                    </group>
                    <group string="Scopes">
                        <field name="allowed_model_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_gf_mcp_api_key" model="ir.actions.act_window">
        <field name="name">MCP API Keys</field>
        <field name="res_model">gf.mcp.api.key</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
