<odoo>
    <record id="view_gf_mcp_audit_log_tree" model="ir.ui.view">
        <field name="name">gf.mcp.audit.log.tree</field>
        <field name="model">gf.mcp.audit.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="create_date"/>
                <field name="api_key_id"/>
                <field name="action"/>
                <field name="model_name"/>
                <field name="record_id"/>
                <field name="status"/>
                <field name="request_ip"/>
            </list>
        </field>
    </record>
    <record id="view_gf_mcp_audit_log_form" model="ir.ui.view">
        <field name="name">gf.mcp.audit.log.form</field>
        <field name="model">gf.mcp.audit.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="api_key_id"/>
                        <field name="action"/>
                        <field name="model_name"/>
                        <field name="record_id"/>
                        <field name="status"/>
                        <field name="request_ip"/>
                        <field name="message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_gf_mcp_audit_log" model="ir.actions.act_window">
        <field name="name">MCP Audit Logs</field>
        <field name="res_model">gf.mcp.audit.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
